# Only used by `npm run start:http` / `start:http:prod` (HTTP transport mode).
# stdio mode (the default — see README) needs none of this.

# Required. Bearer token every /mcp request must present.
MCP_AUTH_TOKEN=

# Required. Comma-separated hostnames this server is reachable at (DNS-rebinding guard).
# For local-only use: localhost,127.0.0.1
MCP_ALLOWED_HOSTS=localhost,127.0.0.1

# Required. Comma-separated absolute directories ingest_repo/generate_spec/etc. may touch.
REBUILD_DOSSIER_ALLOWED_PATHS=

# Optional. Defaults to 8080.
PORT=8080
